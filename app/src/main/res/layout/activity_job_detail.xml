<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HomeAndJobDetails.JobDetailActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/customTopAppBar"
        android:layout_width="match_parent"
        android:layout_height="77dp"
        android:layout_marginTop="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="40dp"
            android:layout_height="60dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/arrow_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Details"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/skipTxt"
            android:layout_width="40dp"
            android:layout_height="60dp"
            android:src="@drawable/archive_bookmark"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="20dp"
            android:gravity="center_horizontal|center_vertical"
            app:layout_constraintBottom_toBottomOf="@+id/titleText"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/titleText" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:id="@+id/jobCardFull"
        android:layout_height="170dp"
        app:cardBackgroundColor="#2969fb"
        app:cardCornerRadius="24dp"
        app:cardElevation="4dp"
        android:layout_margin="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/customTopAppBar"
        app:strokeWidth="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/logoContainer"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_margin="10dp"
                app:cardBackgroundColor="#ffffff"
                app:cardCornerRadius="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:strokeWidth="0dp">

                <ImageView
                    android:id="@+id/imgCompanyLogo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="8dp"
                    android:src="@drawable/google2"
                    android:scaleType="centerInside"/>


            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/txtCompanyName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/sr_ux_designer"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/logoContainer"
                app:layout_constraintTop_toTopOf="@id/logoContainer" />

            <ImageView
                android:id="@+id/imgLocation"
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:src="@drawable/location"
                app:layout_constraintStart_toStartOf="@+id/txtCompanyName"
                app:layout_constraintEnd_toStartOf="@+id/txtJobTitle"
                app:layout_constraintTop_toTopOf="@+id/txtJobTitle"
                app:layout_constraintBottom_toBottomOf="@+id/txtJobTitle" />

            <TextView
                android:id="@+id/txtJobTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/berlin_germany"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:layout_marginStart="2dp"
                app:layout_constraintStart_toEndOf="@+id/imgLocation"
                app:layout_constraintTop_toBottomOf="@id/txtCompanyName" />


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/tagsLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/txtJobTitle">

                <TextView
                    android:id="@+id/textView7"
                    style="@style/JobTagStyle"
                    android:padding="10dp"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/design2"
                    app:layout_constraintEnd_toStartOf="@+id/textView9"
                    app:layout_constraintStart_toEndOf="@+id/textView8" />

                <TextView
                    android:id="@+id/textView8"
                    style="@style/JobTagStyle"
                    android:padding="10dp"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/full_time2"
                    app:layout_constraintEnd_toStartOf="@+id/textView7"
                    app:layout_constraintHorizontal_chainStyle="spread"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/textView9"
                    style="@style/JobTagStyle"
                    android:padding="10dp"
                    app:layout_constraintTop_toTopOf="parent"
                    android:text="@string/in_house"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/textView7" />

            </androidx.constraintlayout.widget.ConstraintLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Tab Container -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        app:tabIndicatorFullWidth="true"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="10dp"
        android:contentDescription="Click on Tab"
        android:background="@drawable/tab_container_bg"
        app:layout_constraintTop_toBottomOf="@id/jobCardFull"
        app:tabBackground="@android:color/transparent"
        app:tabIndicator="@drawable/tab_indicator_bg"
        app:tabIndicatorColor="@null"
        app:tabIndicatorGravity="stretch"
        app:tabMode="fixed"
        app:tabPaddingStart="15dp"
        app:tabPaddingEnd="15dp"
        app:tabMinWidth="0dp"
        app:tabRippleColor="@null"
        app:tabSelectedTextColor="@color/white"
        app:tabTextColor="#2969fb"
        app:tabTextAppearance="@style/TabTextStyle" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        app:layout_constraintBottom_toTopOf="@id/btnApplyThisJob"
        app:layout_constraintTop_toBottomOf="@id/tabLayout" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnApplyThisJob"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_margin="20dp"
        android:text="Apply This Job"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="#2969fb"
        app:cornerRadius="20dp"
        app:layout_constraintBottom_toBottomOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>
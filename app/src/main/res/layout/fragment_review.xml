<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:padding="20dp"
    android:clipChildren="false"
    tools:context=".HomeAndJobDetails.ReviewFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/ratingCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:cardMaxElevation="12dp"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <TextView
                    android:id="@+id/txtRatingBig"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4.6"
                    android:textColor="#1A1D1E"
                    android:textSize="42sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/txtRatingTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/5"
                    android:textColor="#1A1D1E"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/txtRatingBig"
                    app:layout_constraintStart_toEndOf="@id/txtRatingBig"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/txtReviewCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Based on 10K+ Reviews"
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/txtRatingBig" />

                <ProgressBar
                    android:id="@+id/circularProgress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:indeterminate="false"
                    android:max="100"
                    android:padding="10dp"
                    android:progress="75"
                    android:progressDrawable="@drawable/circular_progress_bar"
                    app:layout_constraintBottom_toBottomOf="@id/txtRatingBig"
                    app:layout_constraintStart_toEndOf="@id/txtRatingTotal"
                    app:layout_constraintTop_toTopOf="@id/txtRatingBig" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/circularProgress"
                    app:layout_constraintTop_toTopOf="parent">

                    <LinearLayout style="@style/RatingBarRow">
                        <TextView android:text="5 Star" style="@style/RatingBarLabel" />
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:progress="100"
                            style="@style/RatingBarStyle" />
                    </LinearLayout>

                    <LinearLayout style="@style/RatingBarRow">
                        <TextView android:text="4 Star" style="@style/RatingBarLabel" />
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:progress="75"
                            style="@style/RatingBarStyle" />
                    </LinearLayout>

                    <LinearLayout style="@style/RatingBarRow">
                        <TextView android:text="3 Star" style="@style/RatingBarLabel" />
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:progress="50"
                            style="@style/RatingBarStyle" />
                    </LinearLayout>

                    <LinearLayout style="@style/RatingBarRow">

                        <TextView android:text="2 Star" style="@style/RatingBarLabel" />

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:progress="30"
                            style="@style/RatingBarStyle" />
                    </LinearLayout>

                    <LinearLayout style="@style/RatingBarRow">
                        <TextView android:text="1 Star" style="@style/RatingBarLabel" />

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:progress="20"
                            style="@style/RatingBarStyle" />

                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/txtReviewCount">

                    <ImageView style="@style/StarIcon" android:src="@drawable/star_full" />
                    <ImageView style="@style/StarIcon" android:src="@drawable/star_full" />
                    <ImageView style="@style/StarIcon" android:src="@drawable/star_full" />
                    <ImageView style="@style/StarIcon" android:src="@drawable/star_full" />
                    <ImageView style="@style/StarIcon" android:src="@drawable/star_half" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/txtEmployeeReviewHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Employee Reviews"
            android:textColor="#1A1D1E"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ratingCard" />

        <!-- Filter Dropdown -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="@id/txtEmployeeReviewHeader"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/txtEmployeeReviewHeader">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/book_doc"
                app:tint="#1A1D1E" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Most Recent"
                android:textColor="#1A1D1E"
                android:textSize="14sp" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/arrow_down"
                app:tint="#1A1D1E" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvEmployeeReviews"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/txtEmployeeReviewHeader"
            tools:listitem="@layout/item_review" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/customTopAppBar"
        android:layout_width="match_parent"
        android:layout_height="77dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="40dp"
            android:layout_height="60dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/arrow_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign In"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ImageView
        android:id="@+id/logoLoginImg"
        android:layout_width="110dp"
        android:layout_height="70dp"
        android:src="@drawable/logo_login"
        android:layout_marginStart="22dp"
        app:layout_constraintTop_toBottomOf="@+id/customTopAppBar"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/txtEnterCred"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Give creadential to sign in your account"
        android:textSize="15sp"
        android:textColor="#808080"
        app:layout_constraintStart_toStartOf="@+id/logoLoginImg"
        app:layout_constraintTop_toBottomOf="@+id/logoLoginImg" />

    <TextView
        android:id="@+id/txtEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Email"
        android:textSize="20dp"
        android:textStyle="bold"
        android:layout_marginTop="30dp"
        android:layout_marginStart="10dp"
        app:layout_constraintStart_toStartOf="@+id/txtEnterCred"
        app:layout_constraintTop_toBottomOf="@+id/txtEnterCred"/>

    <EditText
        android:id="@+id/typeEmailEditTxt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/txtEmail"
        android:background="@drawable/edittext_bg"
        android:hint="Type your email"
        android:drawableStart="@drawable/ic_email_resized"
        android:drawablePadding="10dp"
        android:layout_marginTop="10dp"
        android:inputType="textEmailAddress"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="20dp"
        android:padding="12dp"
        />

    <TextView
        android:id="@+id/txtPassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Password"
        android:textSize="20dp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@+id/typeEmailEditTxt"
        app:layout_constraintStart_toStartOf="@+id/txtEmail"
        />

    <EditText
        android:id="@+id/eyeSlashUnfocused"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/txtPassword"
        android:drawableStart="@drawable/ic_password_resized"
        android:drawableEnd="@drawable/ic_eye_slash_password"
        android:drawablePadding="10dp"
        android:layout_marginHorizontal="20dp"
        android:padding="12dp"
        android:hint="Type your password"
        android:layout_marginTop="10dp"
        android:background="@drawable/edittext_bg"
        android:inputType="textPassword"
        />

    <Switch
        android:id="@+id/switchRememberPassword"
        android:layout_width="50dp"
        android:layout_height="60dp"
        app:layout_constraintStart_toStartOf="@+id/eyeSlashUnfocused"
        app:layout_constraintTop_toBottomOf="@+id/eyeSlashUnfocused" />

    <TextView
        android:id="@+id/txtRememberMe"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Remember Me"
        android:textColor="#808080"
        android:layout_marginBottom="4dp"
        app:layout_constraintStart_toEndOf="@+id/switchRememberPassword"
        app:layout_constraintTop_toTopOf="@+id/switchRememberPassword"
        app:layout_constraintBottom_toBottomOf="@+id/switchRememberPassword"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Forgot Password?"
        android:textColor="@color/blue_primary"
        app:layout_constraintTop_toTopOf="@+id/txtRememberMe"
        app:layout_constraintEnd_toEndOf="@+id/eyeSlashUnfocused" />

    <Button
        android:id="@+id/btnSignIn"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:backgroundTint="#2969fb"
        android:text="Sign In"
        android:textColor="@android:color/white"
        app:cornerRadius="15dp"
        app:layout_constraintTop_toBottomOf="@+id/switchRememberPassword"
        app:layout_constraintStart_toStartOf="@+id/switchRememberPassword"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="20dp"
        />

    <LinearLayout
        android:id="@+id/seperatorLine"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="22dp"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnSignIn"
        >

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="#D3D3D3"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="or continue with"
            android:layout_marginHorizontal="8dp"
            android:layout_marginBottom="2dp"
            android:textColor="#888888"
            android:textSize="15sp"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="#D3D3D3"/>

    </LinearLayout>

    <ImageView
        android:id="@+id/googleSignIn"
        android:layout_width="70dp"
        android:layout_height="50dp"
        android:background="@drawable/edittext_bg"
        android:padding="10dp"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintEnd_toStartOf="@+id/appleSignIn"
        app:layout_constraintStart_toEndOf="@+id/facebook"
        app:layout_constraintTop_toTopOf="@id/facebook"
        app:srcCompat="@drawable/google"/>

    <ImageView
        android:id="@+id/appleSignIn"
        android:layout_width="70dp"
        android:layout_height="50dp"
        android:background="@drawable/edittext_bg"
        android:padding="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/facebook"
        app:layout_constraintStart_toEndOf="@+id/googleSignIn"
        app:srcCompat="@drawable/apple"
        />

    <ImageView
        android:id="@+id/facebook"
        android:layout_width="70dp"
        android:layout_height="50dp"
        android:background="@drawable/edittext_bg"
        android:padding="10dp"
        app:layout_constraintEnd_toStartOf="@+id/googleSignIn"
        app:layout_constraintTop_toBottomOf="@+id/seperatorLine"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="10dp"
        app:srcCompat="@drawable/facebook"/>


    <TextView
        android:id="@+id/txtDontHaveAccount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Don't have an account?"
        android:textAlignment="textEnd"
        app:layout_constraintEnd_toStartOf="@+id/txtSignUp"
        android:layout_marginTop="15dp"
        app:layout_constraintTop_toBottomOf="@+id/facebook"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/txtSignUp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sign Up"
        android:textColor="@color/blue_primary"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="6dp"
        app:layout_constraintTop_toTopOf="@+id/txtDontHaveAccount"
        app:layout_constraintStart_toEndOf="@+id/txtDontHaveAccount"/>

</androidx.constraintlayout.widget.ConstraintLayout>
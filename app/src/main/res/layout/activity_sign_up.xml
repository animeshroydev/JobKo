<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sign_in_bg"
    tools:context=".SignUpActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/customTopAppBar"
        android:layout_width="match_parent"
        android:layout_height="77dp"
        android:layout_marginTop="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="40dp"
            android:layout_height="60dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/arrow_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sign_up2"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/customTopAppBar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/logoLoginImg"
                android:layout_width="110dp"
                android:layout_height="70dp"
                android:layout_marginStart="22dp"
                android:src="@drawable/logo_login"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/txtEnterCred"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/give_credential_to_sign_up_your_account"
                android:textColor="#808080"
                android:textSize="15sp"
                app:layout_constraintStart_toStartOf="@+id/logoLoginImg"
                app:layout_constraintTop_toBottomOf="@+id/logoLoginImg" />

            <TextView
                android:id="@+id/txtFullName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginTop="30dp"
                android:text="@string/full_name"
                android:textSize="20dp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="@+id/txtEnterCred"
                app:layout_constraintTop_toBottomOf="@+id/txtEnterCred" />

            <EditText
                android:id="@+id/typeFullName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/edittext_bg"
                android:drawableStart="@drawable/ic_full_name_avatar"
                android:drawablePadding="10dp"
                android:drawableTint="@color/drawable_edit_txt_tint"
                android:hint="@string/type_your_full_name"
                android:inputType="text"
                android:padding="12dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/txtFullName" />


            <TextView
                android:id="@+id/txtEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginTop="10dp"
                android:text="@string/email2"
                android:textSize="20dp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="@+id/typeFullName"
                app:layout_constraintTop_toBottomOf="@+id/typeFullName" />

            <EditText
                android:id="@+id/typeEmailEditTxt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@+id/txtEmail"
                android:background="@drawable/edittext_bg"
                android:hint="@string/type_your_email"
                android:drawableStart="@drawable/ic_email_resized"
                android:drawablePadding="10dp"
                android:layout_marginTop="10dp"
                android:drawableTint="@color/drawable_edit_txt_tint"
                android:inputType="textEmailAddress"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginHorizontal="20dp"
                android:padding="12dp"
                />

            <TextView
                android:id="@+id/txtPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginTop="10dp"
                android:text="@string/password2"
                android:textSize="20dp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="@+id/typeFullName"
                app:layout_constraintTop_toBottomOf="@+id/typeEmailEditTxt" />

            <EditText
                android:id="@+id/editPassword1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@+id/txtPassword"
                android:drawableStart="@drawable/ic_password_resized"
                android:drawableEnd="@drawable/ic_eye_slash_password"
                android:drawablePadding="10dp"
                android:layout_marginHorizontal="20dp"
                android:padding="12dp"
                android:drawableTint="@color/drawable_edit_txt_tint"
                android:hint="@string/type_your_password"
                android:layout_marginTop="10dp"
                android:background="@drawable/edittext_bg"
                android:inputType="textPassword"
                />

            <TextView
                android:id="@+id/CnfmTxtPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginTop="10dp"
                android:text="@string/confirm_password"
                android:textSize="20dp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="@+id/typeFullName"
                app:layout_constraintTop_toBottomOf="@+id/editPassword1" />


            <EditText
                android:id="@+id/confirmPassWordEditTxt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@+id/CnfmTxtPassword"
                android:drawableStart="@drawable/ic_password_resized"
                android:drawableEnd="@drawable/ic_eye_slash_password"
                android:drawablePadding="10dp"
                android:layout_marginHorizontal="20dp"
                android:padding="12dp"
                android:drawableTint="@color/drawable_edit_txt_tint"
                android:hint="@string/type_your_password"
                android:layout_marginTop="10dp"
                android:background="@drawable/edittext_bg"
                android:inputType="textPassword"
                />

            <Button
                android:id="@+id/btnSignUp"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:backgroundTint="#2969fb"
                android:text="@string/sign_up3"
                android:textColor="@android:color/white"
                app:cornerRadius="15dp"
                android:layout_marginTop="25dp"
                app:layout_constraintTop_toBottomOf="@+id/confirmPassWordEditTxt"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginHorizontal="20dp"
                />

            <LinearLayout
                android:id="@+id/seperatorLine"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="25dp"
                android:layout_marginHorizontal="24dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btnSignUp"
                >

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#D3D3D3"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/or_continue_with"
                    android:layout_marginHorizontal="8dp"
                    android:layout_marginBottom="2dp"
                    android:textColor="#888888"
                    android:textSize="15sp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#D3D3D3"/>

            </LinearLayout>

            <ImageView
                android:id="@+id/googleSignIn"
                android:layout_width="70dp"
                android:layout_height="50dp"
                android:background="@drawable/edittext_bg"
                android:padding="10dp"
                android:layout_marginHorizontal="20dp"
                app:layout_constraintEnd_toStartOf="@+id/appleSignIn"
                app:layout_constraintStart_toEndOf="@+id/facebook"
                app:layout_constraintTop_toTopOf="@id/facebook"
                app:srcCompat="@drawable/google"/>

            <ImageView
                android:id="@+id/appleSignIn"
                android:layout_width="70dp"
                android:layout_height="50dp"
                android:background="@drawable/edittext_bg"
                android:padding="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/facebook"
                app:layout_constraintStart_toEndOf="@+id/googleSignIn"
                app:srcCompat="@drawable/apple"
                />

            <ImageView
                android:id="@+id/facebook"
                android:layout_width="70dp"
                android:layout_height="50dp"
                android:background="@drawable/edittext_bg"
                android:padding="10dp"
                app:layout_constraintEnd_toStartOf="@+id/googleSignIn"
                app:layout_constraintTop_toBottomOf="@+id/seperatorLine"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="25dp"
                app:srcCompat="@drawable/facebook"/>

            <TextView
                android:id="@+id/getCodeIn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/already_have_an_account"
                android:textAlignment="textEnd"
                app:layout_constraintEnd_toStartOf="@+id/txtSignIn"
                android:layout_marginTop="15dp"
                app:layout_constraintTop_toBottomOf="@+id/facebook"
                app:layout_constraintHorizontal_chainStyle="packed"
                android:paddingBottom="20dp"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/txtSignIn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sign_in2"
                android:textColor="@color/blue_primary"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginStart="6dp"
                android:paddingBottom="30dp"
                app:layout_constraintTop_toTopOf="@+id/getCodeIn"
                app:layout_constraintStart_toEndOf="@+id/getCodeIn"/>

        </androidx.constraintlayout.widget.ConstraintLayout>


    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>